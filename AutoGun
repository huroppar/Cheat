-- 自作UI付き Auto ShootGunEvent

local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local ShootRemote = RS.Modules.Net["RE/ShootGunEvent"]

getgenv().AutoShootGun = false
getgenv().GunRange = 250
getgenv().GunDelay = 0.03

--========================
-- Target Search
--========================
local function getRoot(char)
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getClosestEnemy()
    local char = player.Character
    if not char then return nil end

    local myRoot = getRoot(char)
    if not myRoot then return nil end

    local enemies = workspace:FindFirstChild("Enemies")
    if not enemies then return nil end

    local closest = nil
    local closestDist = math.huge

    for _, enemy in pairs(enemies:GetChildren()) do
        local hrp = enemy:FindFirstChild("HumanoidRootPart")
        local hum = enemy:FindFirstChildOfClass("Humanoid")

        if hrp and hum and hum.Health > 0 then
            local dist = (hrp.Position - myRoot.Position).Magnitude

            if dist <= getgenv().GunRange and dist < closestDist then
                closestDist = dist
                closest = hrp
            end
        end
    end

    return closest
end

--========================
-- Attack Loop
--========================
task.spawn(function()
    while true do
        pcall(function()
            if getgenv().AutoShootGun then
                local target = getClosestEnemy()

                if target then
                    ShootRemote:FireServer(
                        target.Position,
                        {target}
                    )
                end
            end
        end)

        task.wait(getgenv().GunDelay)
    end
end)

